// Prisma Schema for Sample Application
generator client {
  provider        = "prisma-client"
  previewFeatures = ["views"]
  output          = "../generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["sub"]
}

// ============================================
// User Management
// ============================================

model User {
  id         Int     @id @default(autoincrement()) @map("id")
  publicId   String  @unique @default(cuid()) @map("public_id")
  externalId String? @map("external_id")

  // External Authentication Provider
  authProviderId String @unique @map("auth_provider_id")

  // Profile Information
  email       String  @unique @map("email")
  firstName   String  @map("first_name")
  lastName    String  @map("last_name")
  displayName String? @map("display_name")
  avatarUrl   String? @map("avatar_url")
  phoneNumber String? @map("phone_number")

  // Role and Permissions
  role UserRole @default(SALES_REP) @map("role")

  // Account Status
  isActive        Boolean @default(true) @map("is_active")
  isEmailVerified Boolean @default(false) @map("is_email_verified")

  // Session Management
  lastSignedInAt DateTime? @map("last_signed_in_at") @db.Timestamptz(6)

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  syncedAt  DateTime? @map("synced_at") @db.Timestamptz(6)

  // Relations
  invitationsSent Invitation[] @relation("InvitedBy")
  teamMembers     TeamMember[]

  @@index([publicId])
  @@index([externalId])
  @@index([email])
  @@index([authProviderId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
  @@schema("sub")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES_REP
  VIEWER

  @@schema("sub")
}

// ============================================
// Invitation (招待)
// ============================================

model Invitation {
  id       Int    @id @default(autoincrement()) @map("id")
  publicId String @unique @default(cuid()) @map("public_id")
  token    String @unique @map("token")

  email       String  @map("email")
  firstName   String  @map("first_name")
  lastName    String  @map("last_name")
  displayName String? @map("display_name")

  role UserRole @default(SALES_REP) @map("role")

  status InvitationStatus @default(PENDING) @map("status")

  invitedById Int  @map("invited_by_id")
  invitedBy   User @relation("InvitedBy", fields: [invitedById], references: [id])

  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)

  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  acceptedAt DateTime? @map("accepted_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([token])
  @@index([email])
  @@index([status])
  @@index([invitedById])
  @@index([expiresAt])
  @@map("invitations")
  @@schema("sub")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED

  @@schema("sub")
}

// ============================================
// Team
// ============================================

model Team {
  id       Int    @id @default(autoincrement()) @map("id")
  publicId String @unique @default(cuid()) @map("public_id")

  name String @map("name")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  teamMembers TeamMember[]

  @@index([publicId])
  @@index([deletedAt])
  @@map("teams")
  @@schema("sub")
}

model TeamMember {
  id Int @id @default(autoincrement()) @map("id")

  teamId Int  @map("team_id")
  team   Team @relation(fields: [teamId], references: [id])

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@index([deletedAt])
  @@map("team_members")
  @@schema("sub")
}

// ============================================
// Recruitment Video Management
// ============================================

model Video {
  id       Int    @id @default(autoincrement()) @map("id")
  publicId String @unique @default(cuid()) @map("public_id")

  title        String  @map("title")
  description  String? @map("description")
  category     VideoCategory @map("category")
  subcategory  String? @map("subcategory")
  durationSec  Int?    @map("duration_sec")
  videoUrl     String  @map("video_url")
  thumbnailUrl String? @map("thumbnail_url")
  isPublished  Boolean @default(false) @map("is_published")
  isPinned     Boolean @default(false) @map("is_pinned")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  watchEvents WatchEvent[]

  @@index([publicId])
  @@index([category])
  @@index([isPublished])
  @@index([deletedAt])
  @@map("videos")
  @@schema("sub")
}

enum VideoCategory {
  GOAL_APPEAL
  PEOPLE_APPEAL
  ACTIVITY_APPEAL
  CONDITION_APPEAL
  BRIEFING

  @@schema("sub")
}

model Student {
  id       Int    @id @default(autoincrement()) @map("id")
  publicId String @unique @default(cuid()) @map("public_id")

  atsId      String? @map("ats_id")
  name       String  @map("name")
  email      String  @unique @map("email")
  phone      String? @map("phone")
  university String? @map("university")
  department String? @map("department")

  token          String    @unique @map("token")
  tokenExpiresAt DateTime  @map("token_expires_at") @db.Timestamptz(6)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  watchEvents  WatchEvent[]
  studentMemos StudentMemo[]

  @@index([publicId])
  @@index([email])
  @@index([token])
  @@index([atsId])
  @@index([deletedAt])
  @@map("students")
  @@schema("sub")
}

model WatchEvent {
  id Int @id @default(autoincrement()) @map("id")

  studentId Int     @map("student_id")
  student   Student @relation(fields: [studentId], references: [id])

  videoId Int   @map("video_id")
  video   Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  eventType   WatchEventType @map("event_type")
  positionSec Float          @default(0) @map("position_sec")
  sessionId   String         @map("session_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([studentId])
  @@index([videoId])
  @@index([sessionId])
  @@index([eventType])
  @@map("watch_events")
  @@schema("sub")
}

enum WatchEventType {
  PLAY
  PAUSE
  SEEK
  ENDED
  HEARTBEAT

  @@schema("sub")
}

model StudentMemo {
  id Int @id @default(autoincrement()) @map("id")

  studentId   Int     @map("student_id")
  student     Student @relation(fields: [studentId], references: [id])

  authorEmail String @map("author_email")
  content     String @map("content")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([studentId, authorEmail])
  @@index([studentId])
  @@map("student_memos")
  @@schema("sub")
}

model AuditLog {
  id Int @id @default(autoincrement()) @map("id")

  actorEmail String  @map("actor_email")
  action     String  @map("action")
  targetType String  @map("target_type")
  targetId   String? @map("target_id")
  details    Json?   @map("details")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([actorEmail])
  @@index([targetType])
  @@map("audit_logs")
  @@schema("sub")
}

// ============================================
// Database Views
// ============================================

view VisibleUser {
  id              Int       @unique
  publicId        String    @unique @map("public_id")
  externalId      String?   @map("external_id")
  authProviderId  String    @unique @map("auth_provider_id")
  email           String    @unique
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  displayName     String?   @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  phoneNumber     String?   @map("phone_number")
  role            UserRole
  isActive        Boolean   @map("is_active")
  isEmailVerified Boolean   @map("is_email_verified")
  lastSignedInAt  DateTime? @map("last_signed_in_at") @db.Timestamptz(6)
  createdAt       DateTime  @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  syncedAt        DateTime? @map("synced_at") @db.Timestamptz(6)

  @@map("visible_users")
  @@schema("sub")
}

view VisibleTeam {
  id       Int      @unique
  publicId String   @unique @map("public_id")
  name     String
  createdAt DateTime  @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("visible_teams")
  @@schema("sub")
}

view VisibleTeamMember {
  id     Int @unique
  teamId Int @map("team_id")
  userId Int @map("user_id")
  createdAt DateTime  @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("visible_team_members")
  @@schema("sub")
}

view VisibleVideo {
  id           Int           @unique
  publicId     String        @unique @map("public_id")
  title        String
  description  String?
  category     VideoCategory
  subcategory  String?
  durationSec  Int?          @map("duration_sec")
  videoUrl     String        @map("video_url")
  thumbnailUrl String?       @map("thumbnail_url")
  isPublished  Boolean       @map("is_published")
  isPinned     Boolean       @map("is_pinned")
  createdAt    DateTime      @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz(6)

  @@map("visible_videos")
  @@schema("sub")
}

view VisibleStudent {
  id             Int       @unique
  publicId       String    @unique @map("public_id")
  atsId          String?   @map("ats_id")
  name           String
  email          String    @unique
  phone          String?
  university     String?
  department     String?
  token          String    @unique
  tokenExpiresAt DateTime  @map("token_expires_at") @db.Timestamptz(6)
  createdAt      DateTime  @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("visible_students")
  @@schema("sub")
}

view VisibleInvitation {
  id          Int              @unique
  publicId    String           @unique @map("public_id")
  token       String           @unique
  email       String
  firstName   String           @map("first_name")
  lastName    String           @map("last_name")
  displayName String?          @map("display_name")
  role        UserRole
  status      InvitationStatus
  invitedById Int              @map("invited_by_id")
  expiresAt   DateTime         @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime         @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @map("updated_at") @db.Timestamptz(6)
  acceptedAt  DateTime?        @map("accepted_at") @db.Timestamptz(6)
  deletedAt   DateTime?        @map("deleted_at") @db.Timestamptz(6)

  @@map("visible_invitations")
  @@schema("sub")
}
